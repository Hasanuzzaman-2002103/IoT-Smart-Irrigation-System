function getDashboardData(days) {
  setupSheets_();

  days = Number(days || 1);

  const since = Date.now() - days * 24 * 3600 * 1000;
  const soilCalib = soilCalibrationObject_();

  const nodeRows = rowsToObjects_(TABS.NODE)
    .filter(r => new Date(r.Timestamp).getTime() >= since)
    .slice(-300)
    .map(r => enhanceNodeRowObject_(r, soilCalib));

  const hubRows = rowsToObjects_(TABS.HUB)
    .filter(r => new Date(r.Timestamp).getTime() >= since)
    .slice(-300);

  const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd');
  const motorToday = motorLogReport_(today, today, 'ALL').summary;

  return {
    ok: true,
    settings: settingsMap_(),
    latestNode: latestNodeObject_(),
    nodeRows: nodeRows,
    hubRows: hubRows,
    schedules: scheduleArray_(),
    crops: cropRows_(),
