function getSuggestion(crop) {
  setupSheets_();

  const latest = latestNodeObject_();
  const rows = cropRows_();
  const target = rows.find(r => String(r.Crop).toLowerCase() === String(crop).toLowerCase());

  if (!latest) return { ok: false, error: 'No Node data yet' };
  if (!target) return { ok: false, error: 'Crop not found' };

  const checks = [
    compare_('Nitrogen', latest.nCal, target.N),
    compare_('Phosphorus', latest.pCal, target.P),
    compare_('Potassium', latest.kCal, target.K),
    compare_('Soil pH', latest.phCal, target.pH),
    compare_('Electrical Conductivity', latest.ec, target.EC),
    compare_('Soil Moisture', latest.moistureCal, target.Moisture),
    compare_('Soil Temperature', latest.soilTemp, target['Soil Temp'])
  ];

  return {
    ok: true,
    crop: crop,
    latest: latest,
    target: target,
    lines: checks.map(c => c.message)
  };
}

function compare_(name, current, target) {
  current = Number(current);
  target = Number(target);

  if (isNaN(current) || isNaN(target)) {
    return {
      name: name,
      message: name + ': data unavailable.'
    };
  }

  const diff = current - target;
  const pct = target === 0 ? 0 : Math.abs(diff) / Math.abs(target) * 100;

  if (pct <= 10) {
    return {
      name: name,
      message: name + ': OK. Current ' + current + ', target ' + target + '.'
    };
  }

  if (diff < 0) {
    return {
      name: name,
      message: name + ': low. Current ' + current + ', target ' + target + '. Consider increasing/supporting this value.'
    };
  }

  return {
    name: name,
    message: name + ': high. Current ' + current + ', target ' + target + '. Avoid adding more and monitor.'
  };
}

function getCsvData(tab, startDate, endDate, mode) {
  setupSheets_();

  tab = String(tab || '').trim();

  if (tab === 'MotorLog') {
    return getMotorLogReport(startDate, endDate, mode || 'ALL');
  }

  const sheetTab = tab === 'HubData' ? TABS.HUB : TABS.NODE;
  const soilCalib = soilCalibrationObject_();

  let rows = rowsToObjects_(sheetTab);

  if (sheetTab === TABS.NODE) {
    rows = rows.map(r => enhanceNodeRowObject_(r, soilCalib));
  }

  const s = startDate ? new Date(startDate + 'T00:00:00').getTime() : 0;
  const e = endDate ? new Date(endDate + 'T23:59:59').getTime() : Date.now();

  const filtered = rows.filter(r => {
    const t = new Date(r.Timestamp).getTime();
    return t >= s && t <= e;
  });

  return {
    ok: true,
    rows: filtered
  };
}

