    gasLabels: GAS_SENSOR_LABELS,
    soilParameters: SOIL_PARAMETERS
  };
}

function rowsToObjects_(tab) {
  const values = sh_(tab).getDataRange().getValues();

  if (values.length < 2) return [];

  const h = values[0];

  return values.slice(1).filter(r => r.some(c => c !== '')).map(r => {
    const o = {};

    h.forEach((k, i) => {
      let v = r[i];

      if (v instanceof Date) {
        v = Utilities.formatDate(v, Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss');
      }

      o[k] = v;
    });

    return o;
  });
}

